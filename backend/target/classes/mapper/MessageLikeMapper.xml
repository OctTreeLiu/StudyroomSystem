<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.studyspace.mapper.MessageLikeMapper">

    <resultMap id="BaseResultMap" type="com.studyspace.entity.MessageLike">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="message_id" property="messageId" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <select id="selectByMessageIdAndUserId" resultMap="BaseResultMap">
        SELECT id, message_id, user_id, create_time
        FROM message_like
        WHERE message_id = #{messageId} AND user_id = #{userId}
        LIMIT 1
    </select>

    <select id="countByMessageId" resultType="int">
        SELECT COUNT(*)
        FROM message_like
        WHERE message_id = #{messageId}
    </select>

    <insert id="insert" parameterType="com.studyspace.entity.MessageLike" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO message_like (message_id, user_id)
        VALUES (#{messageId}, #{userId})
    </insert>

    <delete id="deleteByMessageIdAndUserId">
        DELETE FROM message_like WHERE message_id = #{messageId} AND user_id = #{userId}
    </delete>

    <delete id="deleteByMessageId">
        DELETE FROM message_like WHERE message_id = #{messageId}
    </delete>

</mapper>

