<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.studyspace.mapper.MemberOrderMapper">

    <resultMap id="BaseResultMap" type="com.studyspace.entity.MemberOrder">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="order_number" property="orderNumber" jdbcType="VARCHAR"/>
        <result column="member_type" property="memberType" jdbcType="TINYINT"/>
        <result column="amount" property="amount" jdbcType="DECIMAL"/>
        <result column="payment_status" property="paymentStatus" jdbcType="TINYINT"/>
        <result column="status" property="status" jdbcType="TINYINT"/>
        <result column="payment_time" property="paymentTime" jdbcType="TIMESTAMP"/>
        <result column="start_date" property="startDate" jdbcType="DATE"/>
        <result column="end_date" property="endDate" jdbcType="DATE"/>
        <result column="points_awarded" property="pointsAwarded" jdbcType="INTEGER"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
        <result column="username" property="username" jdbcType="VARCHAR"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, order_number, member_type, amount, payment_status, status, payment_time,
        start_date, end_date, points_awarded, create_time, update_time
    </sql>

    <insert id="insert" parameterType="com.studyspace.entity.MemberOrder" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO member_order (user_id, order_number, member_type, amount, payment_status, status,
                                 start_date, end_date, points_awarded)
        VALUES (#{userId}, #{orderNumber}, #{memberType}, #{amount}, #{paymentStatus}, #{status},
                 #{startDate}, #{endDate}, #{pointsAwarded})
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM member_order
        WHERE id = #{id}
    </select>

    <select id="selectByOrderNumber" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM member_order
        WHERE order_number = #{orderNumber}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM member_order
        WHERE user_id = #{userId}
        ORDER BY create_time DESC
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>,
               u.username
        FROM member_order mo
        LEFT JOIN user u ON mo.user_id = u.id
        ORDER BY mo.create_time DESC
    </select>

    <update id="update" parameterType="com.studyspace.entity.MemberOrder">
        UPDATE member_order
        <set>
            <if test="paymentStatus != null">payment_status = #{paymentStatus},</if>
            <if test="status != null">status = #{status},</if>
            <if test="paymentTime != null">payment_time = #{paymentTime},</if>
            update_time = NOW(),
        </set>
        WHERE id = #{id}
    </update>

    <select id="selectTimeoutUnpaidOrders" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM member_order
        WHERE payment_status = 0
          AND (status IS NULL OR status = 0)
          AND create_time &lt; DATE_SUB(NOW(), INTERVAL #{minutes} MINUTE)
    </select>


</mapper>

